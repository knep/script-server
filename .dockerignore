# Version control
.git/
.github/

# Frontend source — pre-built assets are already committed to web/
web-src/

# Dev / build tooling
tools/build.py
tools/deploy_docker.sh
tools/init.py
tools/run_e2e_tests.sh
tools/start_in_virtualenv.sh
samples/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/

# Tests (not needed at runtime)
src/tests/
src/e2e_tests/

# Coverage / test artifacts
coverage.xml
src/coverage.xml
.coverage
htmlcov/
web-src/coverage/
.coveragerc

# Docs
*.md
LICENSE

# macOS
.DS_Store

# IDE / local tooling
.vscode/
.idea/
.claude/

# Runtime directories (mounted as volumes)
conf/runners/
logs/

# Personal / local config — never ship in the image. Scripts and runner
# configs are provided at runtime (mounted volumes); conf.json holds local
# server settings (the image uses script-server defaults: port 5000 = EXPOSE).
# These are untracked in git, so the CI-built image already excludes them;
# this keeps local `docker build` consistent with the published image.
conf/scripts/
conf/conf.json
conf/schedules/
conf/deleted/
